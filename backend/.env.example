# LLM & RAG Configuration
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PATH=./company_data/chroma_db
DATABASE_URL=sqlite:///./banking.db
COMPANY_DOCS=./company_data/documents

# Allowed Frontend Origins for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.vercel.app

# LiveKit Voice Credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
